{
  "name": "trevean-nfc-mobile",
  "version": "0.1.0",
  "description": "React Native NFC SDK for Trevean Spice smart packaging",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build:android": "cd android && ./gradlew clean assembleRelease",
    "build:ios": "xcodebuild -workspace ios/TreveanNFC.xcworkspace -scheme TreveanNFC -configuration Release",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-nfc-manager": "^3.14.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.25.0",
    "react-native-safe-area-context": "^4.7.0",
"@react-native-community/async-storage": "^1.12.1",
    "react-native-gesture-handler": "^2.13.0"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.73.0",
    "@types/react-native": "^0.73.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.0.0"
  }
}
